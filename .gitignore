# ML / experiment artefacts (large, mostly regenerable)
# Use /* not / so .gitkeep negations below work (git can't re-include
# files inside a fully-ignored directory)
data/*
checkpoints/*
models/*
wandb/
mlruns/
runs/
outputs/
*.pt
*.pth
*.safetensors
*.bin
*.gguf

# Keep .gitkeep stubs so empty dirs survive
!data/.gitkeep
!checkpoints/.gitkeep
!models/.gitkeep

# Logs
*.log
logs/

# Local config
.env
.env.local
