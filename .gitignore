# ML / experiment artefacts (large, mostly regenerable)
# Use /* not / so .gitkeep negations below work (git can't re-include
# files inside a fully-ignored directory)
data/*
checkpoints/*
**/checkpoints/
# Stage 2dash trains a local model + caches a multi-GB corpus here (root rule above
# only matches /checkpoints, not this nested path).
notebooks/education/checkpoints/
models/*
wandb/
mlruns/
runs/
outputs/
*.pt
*.pth
*.safetensors
*.bin
*.gguf

# Keep .gitkeep stubs so empty dirs survive
!data/.gitkeep
!checkpoints/.gitkeep
!models/.gitkeep

# Logs
*.log
logs/

# Local config
.env
.env.local
.superpowers/

# Phase A trained model checkpoints (large binaries; regenerate via run_probes.py)
experiments/embedding-probes/checkpoints/

# Superposition book two caches sweep/dynamics runs here
notebooks/superposition/cache/
